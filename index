<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sánchez Motor — Gestión de Taller</title>
<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<style>
:root{
  --azul-900:#0f2a52;
  --azul-700:#1d4e8f;
  --azul-600:#2563b3;
  --azul-100:#e6edf7;
  --papel:#fbf9f4;
  --papel-2:#f3efe4;
  --metal:#4b5566;
  --metal-2:#7c8696;
  --oxido:#c2540a;
  --oxido-100:#fbe6d5;
  --verde:#2f6b3f;
  --verde-100:#e3efe1;
  --linea:#d8d2c2;
  --tinta:#1c2230;
  --sombra: 0 2px 10px rgba(15,42,82,0.08);
}
*{box-sizing:border-box;}
html,body{margin:0;padding:0;}
body{
  background:var(--papel);
  background-image:
    radial-gradient(circle at 0% 0%, rgba(29,78,143,0.04), transparent 40%),
    radial-gradient(circle at 100% 0%, rgba(194,84,10,0.03), transparent 40%);
  color:var(--tinta);
  font-family:'Inter',system-ui,-apple-system,Segoe UI,Roboto,sans-serif;
  min-height:100vh;
}
#root{min-height:100vh;}

.brand-font{
  font-family:'Oswald', 'Arial Narrow', sans-serif;
  letter-spacing:0.02em;
}

/* ---------- Login ---------- */
.login-wrap{
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:24px;
  position:relative;
  overflow:hidden;
}
.login-wrap::before{
  content:"";
  position:absolute;
  inset:0;
  background:
    repeating-linear-gradient(135deg, rgba(15,42,82,0.025) 0px, rgba(15,42,82,0.025) 2px, transparent 2px, transparent 14px);
  pointer-events:none;
}
.login-card{
  position:relative;
  background:#fff;
  border:1px solid var(--linea);
  border-radius:4px;
  padding:40px 36px 32px;
  width:100%;
  max-width:380px;
  box-shadow: 0 12px 40px rgba(15,42,82,0.12);
}
.login-card::before{
  content:"";
  position:absolute;
  top:14px; left:14px; right:14px; bottom:14px;
  border:1px dashed var(--linea);
  pointer-events:none;
  border-radius:2px;
}
.stamp-logo{
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:6px;
  margin-bottom:22px;
}
.stamp-logo svg{width:78px;height:78px;}
.brand-title{
  font-size:1.7rem;
  font-weight:600;
  color:var(--azul-700);
  text-transform:uppercase;
  text-align:center;
  line-height:1.1;
}
.brand-sub{
  font-size:0.72rem;
  color:var(--metal);
  text-transform:uppercase;
  letter-spacing:0.12em;
  text-align:center;
  margin-top:2px;
}
.login-form label{
  display:block;
  font-size:0.72rem;
  text-transform:uppercase;
  letter-spacing:0.08em;
  color:var(--metal);
  margin:16px 0 6px;
  font-weight:600;
}
.login-form input{
  width:100%;
  padding:11px 12px;
  border:1px solid var(--linea);
  border-radius:3px;
  font-size:0.95rem;
  background:var(--papel);
  font-family:inherit;
}
.login-form input:focus{
  outline:2px solid var(--azul-600);
  outline-offset:1px;
  background:#fff;
}
.btn{
  border:none;
  border-radius:3px;
  padding:11px 18px;
  font-size:0.85rem;
  font-weight:600;
  text-transform:uppercase;
  letter-spacing:0.06em;
  cursor:pointer;
  font-family:inherit;
  transition:transform 0.05s ease, box-shadow 0.15s ease;
}
.btn:active{transform:translateY(1px);}
.btn-primary{background:var(--azul-700);color:#fff;}
.btn-primary:hover{background:var(--azul-900);}
.btn-primary:focus-visible{outline:2px solid var(--oxido);outline-offset:2px;}
.btn-block{width:100%;margin-top:18px;}
.login-error{
  margin-top:14px;
  background:var(--oxido-100);
  color:#7a3206;
  border:1px solid #e3a87a;
  padding:9px 11px;
  border-radius:3px;
  font-size:0.82rem;
}
.login-foot{
  text-align:center;
  margin-top:22px;
  font-size:0.7rem;
  color:var(--metal-2);
  text-transform:uppercase;
  letter-spacing:0.08em;
}

/* ---------- App shell ---------- */
.app-shell{display:flex;min-height:100vh;}
.sidebar{
  width:230px;
  background:var(--azul-900);
  color:#dbe6f5;
  display:flex;
  flex-direction:column;
  flex-shrink:0;
}
.sidebar-head{
  padding:22px 18px 18px;
  border-bottom:1px solid rgba(255,255,255,0.12);
  display:flex;
  align-items:center;
  gap:10px;
}
.sidebar-head svg{width:36px;height:36px;flex-shrink:0;}
.sidebar-head-text{font-size:1.02rem;font-weight:600;color:#fff;text-transform:uppercase;line-height:1.15;}
.sidebar-head-sub{font-size:0.62rem;color:#a9c0de;text-transform:uppercase;letter-spacing:0.1em;}
.nav{flex:1;padding:14px 10px;}
.nav-item{
  display:flex;
  align-items:center;
  gap:10px;
  padding:11px 12px;
  border-radius:4px;
  color:#c3d4ea;
  cursor:pointer;
  font-size:0.85rem;
  font-weight:500;
  margin-bottom:3px;
  border:none;
  background:none;
  width:100%;
  text-align:left;
  font-family:inherit;
}
.nav-item:hover{background:rgba(255,255,255,0.06);color:#fff;}
.nav-item.active{background:var(--azul-700);color:#fff;}
.nav-item svg{width:17px;height:17px;flex-shrink:0;}
.sidebar-foot{
  padding:14px 16px 18px;
  border-top:1px solid rgba(255,255,255,0.12);
}
.sidebar-user{font-size:0.78rem;color:#a9c0de;margin-bottom:8px;}
.logout-btn{
  background:none;
  border:1px solid rgba(255,255,255,0.25);
  color:#dbe6f5;
  padding:7px 10px;
  border-radius:3px;
  font-size:0.74rem;
  cursor:pointer;
  width:100%;
  text-transform:uppercase;
  letter-spacing:0.05em;
}
.logout-btn:hover{background:rgba(255,255,255,0.08);}

.main{
  flex:1;
  min-width:0;
  padding:28px 32px 60px;
  max-width:1200px;
}
.page-head{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  flex-wrap:wrap;
  gap:14px;
  margin-bottom:24px;
  border-bottom:2px solid var(--azul-900);
  padding-bottom:14px;
}
.page-title{
  font-size:1.5rem;
  font-weight:600;
  color:var(--azul-900);
  text-transform:uppercase;
}
.page-eyebrow{
  font-size:0.72rem;
  color:var(--oxido);
  text-transform:uppercase;
  letter-spacing:0.1em;
  font-weight:700;
  margin-bottom:2px;
}

/* mobile topbar */
.mobile-topbar{
  display:none;
  background:var(--azul-900);
  color:#fff;
  align-items:center;
  justify-content:space-between;
  padding:12px 16px;
  position:sticky;
  top:0;
  z-index:50;
}
.mobile-topbar svg{width:26px;height:26px;}
.mobile-topbar-title{font-size:0.95rem;font-weight:600;text-transform:uppercase;}
.burger{background:none;border:none;color:#fff;font-size:1.5rem;cursor:pointer;padding:4px 8px;}

/* ---------- Cards / common ---------- */
.card{
  background:#fff;
  border:1px solid var(--linea);
  border-radius:4px;
  padding:20px 22px;
  box-shadow:var(--sombra);
  margin-bottom:20px;
}
.card-title{
  font-size:0.95rem;
  font-weight:700;
  color:var(--azul-900);
  text-transform:uppercase;
  letter-spacing:0.03em;
  margin:0 0 14px;
  padding-bottom:10px;
  border-bottom:1px solid var(--papel-2);
}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}
@media (max-width: 720px){
  .grid-2,.grid-3{grid-template-columns:1fr;}
}
.field label{
  display:block;
  font-size:0.68rem;
  text-transform:uppercase;
  letter-spacing:0.07em;
  color:var(--metal);
  font-weight:700;
  margin-bottom:5px;
}
.field input, .field select, .field textarea{
  width:100%;
  padding:9px 10px;
  border:1px solid var(--linea);
  border-radius:3px;
  font-size:0.9rem;
  font-family:inherit;
  background:#fffefb;
}
.field textarea{resize:vertical;min-height:70px;}
.field input:focus, .field select:focus, .field textarea:focus{
  outline:2px solid var(--azul-600);
  outline-offset:1px;
}
.field{margin-bottom:12px;}

.btn-secondary{
  background:#fff;
  color:var(--azul-700);
  border:1.5px solid var(--azul-700);
}
.btn-secondary:hover{background:var(--azul-100);}
.btn-danger{background:#fff;color:#a32626;border:1.5px solid #a32626;}
.btn-danger:hover{background:#fbe9e9;}
.btn-oxido{background:var(--oxido);color:#fff;}
.btn-oxido:hover{background:#9c4108;}
.btn-sm{padding:6px 11px;font-size:0.72rem;}
.btn-row{display:flex;gap:10px;flex-wrap:wrap;margin-top:6px;}

table{width:100%;border-collapse:collapse;font-size:0.86rem;}
thead th{
  text-align:left;
  font-size:0.68rem;
  text-transform:uppercase;
  letter-spacing:0.06em;
  color:var(--metal);
  font-weight:700;
  padding:8px 10px;
  border-bottom:2px solid var(--azul-900);
}
tbody td{padding:10px 10px;border-bottom:1px solid var(--papel-2);vertical-align:middle;}
tbody tr:hover{background:var(--papel-2);}
.table-wrap{overflow-x:auto;}

.badge{
  display:inline-flex;
  align-items:center;
  gap:5px;
  padding:3px 9px;
  border-radius:20px;
  font-size:0.68rem;
  font-weight:700;
  text-transform:uppercase;
  letter-spacing:0.04em;
}
.badge-ok{background:var(--verde-100);color:var(--verde);}
.badge-pend{background:var(--oxido-100);color:var(--oxido);}
.badge-neutral{background:var(--azul-100);color:var(--azul-700);}

.empty-state{
  text-align:center;
  padding:50px 20px;
  color:var(--metal-2);
}
.empty-state svg{width:50px;height:50px;margin-bottom:12px;opacity:0.5;}
.empty-state-title{font-weight:600;color:var(--metal);margin-bottom:4px;}
.empty-state-sub{font-size:0.85rem;}

.search-bar{
  display:flex;
  gap:10px;
  margin-bottom:18px;
  flex-wrap:wrap;
}
.search-bar input{
  flex:1;
  min-width:200px;
  padding:10px 14px;
  border:1px solid var(--linea);
  border-radius:3px;
  font-size:0.9rem;
  font-family:inherit;
}
.search-bar input:focus{outline:2px solid var(--azul-600);outline-offset:1px;}

.client-row{cursor:pointer;}
.tag-pill{
  display:inline-block;
  background:var(--azul-100);
  color:var(--azul-700);
  padding:2px 9px;
  border-radius:3px;
  font-size:0.74rem;
  font-weight:600;
  margin:2px 3px 0 0;
}

.modal-overlay{
  position:fixed;inset:0;
  background:rgba(15,20,30,0.45);
  display:flex;align-items:center;justify-content:center;
  z-index:100;
  padding:18px;
}
.modal{
  background:#fff;
  border-radius:5px;
  max-width:560px;
  width:100%;
  max-height:88vh;
  overflow-y:auto;
  padding:26px 26px 22px;
  box-shadow:0 20px 60px rgba(0,0,0,0.25);
}
.modal-head{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:16px;
}
.modal-title{font-size:1.05rem;font-weight:700;color:var(--azul-900);text-transform:uppercase;}
.modal-close{background:none;border:none;font-size:1.4rem;color:var(--metal);cursor:pointer;line-height:1;}

/* ---------- Ficha cliente detail ---------- */
.work-tab{
  background:var(--papel-2);
  border:1px solid var(--linea);
  border-left:4px solid var(--azul-700);
  border-radius:3px;
  padding:14px 16px;
  margin-bottom:12px;
}
.work-tab.pend{border-left-color:var(--oxido);}
.work-tab-head{
  display:flex;justify-content:space-between;align-items:flex-start;gap:10px;flex-wrap:wrap;
  margin-bottom:6px;
}
.work-tab-date{font-size:0.72rem;color:var(--metal);text-transform:uppercase;font-weight:700;}
.work-tab-desc{font-size:0.9rem;color:var(--tinta);margin:6px 0;}
.work-tab-parts{font-size:0.8rem;color:var(--metal);}
.work-tab-price{font-weight:700;color:var(--azul-900);font-size:0.95rem;}

.summary-row{
  display:flex;justify-content:space-between;
  padding:6px 0;
  font-size:0.9rem;
  border-bottom:1px solid var(--papel-2);
}
.summary-row.total{
  font-size:1.05rem;font-weight:700;color:var(--azul-900);
  border-bottom:none;border-top:2px solid var(--azul-900);
  padding-top:10px;margin-top:6px;
}

/* ---------- Invoice / print ---------- */
.invoice-paper{
  background:#fff;
  border:1px solid var(--linea);
  padding:36px;
  max-width:760px;
  margin:0 auto;
  box-shadow:var(--sombra);
}
.invoice-top{
  display:flex;justify-content:space-between;align-items:flex-start;
  border-bottom:3px solid var(--azul-900);
  padding-bottom:18px;margin-bottom:18px;
  flex-wrap:wrap;gap:16px;
}
.invoice-brand{display:flex;gap:12px;align-items:center;}
.invoice-brand svg{width:54px;height:54px;}
.invoice-brand-name{font-size:1.25rem;font-weight:700;color:var(--azul-700);text-transform:uppercase;}
.invoice-brand-sub{font-size:0.72rem;color:var(--metal);}
.invoice-meta{text-align:right;font-size:0.82rem;color:var(--metal);}
.invoice-meta strong{color:var(--azul-900);font-size:1.1rem;display:block;}
.invoice-stamp{
  position:relative;
  display:inline-block;
  border:3px solid var(--oxido);
  color:var(--oxido);
  border-radius:50%;
  width:90px;height:90px;
  text-align:center;
  font-size:0.7rem;
  font-weight:800;
  text-transform:uppercase;
  transform:rotate(-12deg);
  display:flex;align-items:center;justify-content:center;
  letter-spacing:0.02em;
  opacity:0.85;
}
.invoice-stamp.pagado{border-color:var(--verde);color:var(--verde);}
.invoice-section-title{
  font-size:0.7rem;text-transform:uppercase;letter-spacing:0.08em;
  color:var(--metal);font-weight:700;margin-bottom:6px;
}
.invoice-cols{display:flex;justify-content:space-between;gap:24px;margin-bottom:22px;flex-wrap:wrap;}
.invoice-col{flex:1;min-width:200px;}
.invoice-col p{margin:2px 0;font-size:0.88rem;}
table.invoice-table{margin-bottom:18px;}
table.invoice-table thead th{background:var(--azul-100);}
.invoice-totals{
  margin-left:auto;
  max-width:280px;
}
.invoice-footer-note{
  margin-top:26px;
  font-size:0.72rem;
  color:var(--metal-2);
  border-top:1px solid var(--papel-2);
  padding-top:12px;
  text-align:center;
}
.qr-box{
  display:flex;align-items:center;gap:14px;margin-top:18px;
  border-top:1px dashed var(--linea);padding-top:16px;
}
.qr-box img{width:84px;height:84px;border:1px solid var(--linea);}
.qr-box-text{font-size:0.7rem;color:var(--metal-2);line-height:1.5;}

@media print{
  .no-print{display:none !important;}
  body{background:#fff;}
  .invoice-paper{border:none;box-shadow:none;padding:0;}
  .main{padding:0;}
}

@media (max-width: 880px){
  .sidebar{display:none;}
  .mobile-topbar{display:flex;}
  .app-shell{flex-direction:column;}
  .main{padding:18px 16px 50px;}
  .invoice-paper{padding:20px;}
  .invoice-top{flex-direction:column;}
  .invoice-meta{text-align:left;}
}
.sidebar.mobile-open{
  display:flex;
  position:fixed;
  inset:0 30% 0 0;
  z-index:60;
  box-shadow:8px 0 30px rgba(0,0,0,0.3);
}
.sidebar-scrim{
  display:none;
}
.sidebar-scrim.show{
  display:block;
  position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:55;
}

.toast{
  position:fixed;
  bottom:24px;right:24px;
  background:var(--azul-900);
  color:#fff;
  padding:12px 18px;
  border-radius:4px;
  font-size:0.85rem;
  box-shadow:0 6px 20px rgba(0,0,0,0.25);
  z-index:200;
  max-width:320px;
}
.toast.error{background:#a32626;}

.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px;}
@media (max-width:880px){.kpi-row{grid-template-columns:1fr 1fr;}}
.kpi{
  background:#fff;border:1px solid var(--linea);border-radius:4px;
  padding:16px 18px;box-shadow:var(--sombra);
}
.kpi-label{font-size:0.68rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--metal);font-weight:700;}
.kpi-value{font-size:1.6rem;font-weight:700;color:var(--azul-900);margin-top:4px;}
.kpi-value.oxido{color:var(--oxido);}

.icon-btn{
  background:none;border:none;cursor:pointer;color:var(--metal);
  padding:5px;border-radius:3px;display:inline-flex;
}
.icon-btn:hover{background:var(--papel-2);color:var(--azul-700);}
.icon-btn svg{width:17px;height:17px;}
.icon-btn.danger:hover{color:#a32626;}

a{color:var(--azul-700);}
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel" data-presets="react">
const { useState, useEffect, useCallback, useRef } = React;

/* ============ DATOS DEL TALLER ============ */
const TALLER = {
  nombre: "Sánchez Motor",
  actividad: "Electromecánica y Neumáticos",
  titular: "Antonio M. Sánchez Triguero",
  nif: "80.058.091-J",
  direccion: "C/ Huerta San Juan S/N",
  cp: "06160",
  localidad: "Barcarrota (Badajoz)",
};

const USUARIO_VALIDO = "sanchezMotor";
const PASS_VALIDA = "adminSanchezMotor987";

/* ============ LOGO SVG (sello del taller) ============ */
function LogoMark({ size = 60 }) {
  return (
    <svg viewBox="0 0 100 100" width={size} height={size} xmlns="http://www.w3.org/2000/svg">
      <circle cx="50" cy="50" r="47" fill="none" stroke="currentColor" strokeWidth="2.5" />
      <path d="M22 58 L30 40 Q33 34 40 34 L62 34 Q69 34 72 40 L80 58"
            fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round" />
      <path d="M18 58 L84 58" stroke="currentColor" strokeWidth="3" strokeLinecap="round" />
      <circle cx="32" cy="60" r="6" fill="none" stroke="currentColor" strokeWidth="3" />
      <circle cx="70" cy="60" r="6" fill="none" stroke="currentColor" strokeWidth="3" />
      <path d="M40 34 L44 22 L58 22 L62 34" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" />
      <path d="M65 70 Q75 70 78 78 Q80 84 74 86 Q66 88 62 80" fill="none" stroke="currentColor" strokeWidth="2.2" strokeLinecap="round" />
    </svg>
  );
}

/* ============ STORAGE HELPERS ============ */
async function dbGet(key, fallback) {
  try {
    const res = await window.storage.get(key, false);
    if (!res) return fallback;
    return JSON.parse(res.value);
  } catch (e) {
    return fallback;
  }
}
async function dbSet(key, value) {
  try {
    await window.storage.set(key, JSON.stringify(value), false);
    return true;
  } catch (e) {
    console.error("Error guardando", key, e);
    return false;
  }
}

/* ============ UTILIDADES ============ */
function uid(prefix) {
  return prefix + "_" + Date.now().toString(36) + Math.random().toString(36).slice(2, 7);
}
function euros(n) {
  const v = Number(n) || 0;
  return v.toLocaleString("es-ES", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + " €";
}
function hoy() {
  return new Date().toISOString().slice(0, 10);
}
function fechaBonita(iso) {
  if (!iso) return "—";
  const [y, m, d] = iso.split("-");
  return `${d}/${m}/${y}`;
}
function numeroFactura(seq, year) {
  return `SM-${year}-${String(seq).padStart(4, "0")}`;
}

/* QR simple (vía API pública de QR, solo para representar el enlace de la factura -
   en producción VeriFactu el QR codifica NIF+numero+fecha+importe+hash conforme a especificación AEAT) */
function qrUrl(text) {
  const encoded = encodeURIComponent(text);
  return `https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=${encoded}`;
}

/* Hash simple encadenado (simulación local del encadenado tipo VeriFactu - NO es el algoritmo oficial) */
function hashSimple(str) {
  let h = 0;
  for (let i = 0; i < str.length; i++) {
    h = (Math.imul(31, h) + str.charCodeAt(i)) | 0;
  }
  return (h >>> 0).toString(16).padStart(8, "0");
}

/* ============ TOAST ============ */
function Toast({ toast, onClose }) {
  useEffect(() => {
    if (!toast) return;
    const t = setTimeout(onClose, 3000);
    return () => clearTimeout(t);
  }, [toast]);
  if (!toast) return null;
  return (
    <div className={"toast" + (toast.type === "error" ? " error" : "")} role="status">
      {toast.msg}
    </div>
  );
}

