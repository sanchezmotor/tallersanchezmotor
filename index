/* ============ PIEZAS / STOCK ============ */
function FormPieza({ inicial, onSave, onCancel }) {
  const [form, setForm] = useState(inicial || {
    nombre: "", referencia: "", precio: "", stock: "", stockMin: "", proveedor: ""
  });
  function upd(k, v) { setForm((f) => ({ ...f, [k]: v })); }
  function submit(e) {
    e.preventDefault();
    if (!form.nombre.trim()) return;
    onSave({ ...form, precio: Number(form.precio) || 0, stock: Number(form.stock) || 0, stockMin: Number(form.stockMin) || 0 });
  }
  return (
    <form onSubmit={submit}>
      <div className="grid-2">
        <div className="field">
          <label>Nombre de la pieza *</label>
          <input value={form.nombre} onChange={(e) => upd("nombre", e.target.value)} placeholder="Filtro de aceite" autoFocus />
        </div>
        <div className="field">
          <label>Referencia</label>
          <input value={form.referencia} onChange={(e) => upd("referencia", e.target.value)} placeholder="REF-00123" />
        </div>
      </div>
      <div className="grid-3">
        <div className="field">
          <label>Precio unidad (€)</label>
          <input type="number" step="0.01" min="0" value={form.precio} onChange={(e) => upd("precio", e.target.value)} placeholder="0.00" />
        </div>
        <div className="field">
          <label>Stock actual</label>
          <input type="number" min="0" value={form.stock} onChange={(e) => upd("stock", e.target.value)} placeholder="0" />
        </div>
        <div className="field">
          <label>Stock mínimo (aviso)</label>
          <input type="number" min="0" value={form.stockMin} onChange={(e) => upd("stockMin", e.target.value)} placeholder="0" />
        </div>
      </div>
      <div className="field">
        <label>Proveedor</label>
        <input value={form.proveedor} onChange={(e) => upd("proveedor", e.target.value)} placeholder="Opcional" />
      </div>
      <div className="btn-row">
        <button type="submit" className="btn btn-primary">Guardar pieza</button>
        <button type="button" className="btn btn-secondary" onClick={onCancel}>Cancelar</button>
      </div>
    </form>
  );
}

function Piezas({ piezas, setPiezas, notify }) {
  const [busqueda, setBusqueda] = useState("");
  const [modal, setModal] = useState(null); // null | "nueva" | {edit: pieza}
  const [confirmDelete, setConfirmDelete] = useState(null);

  const filtradas = piezas.filter((p) =>
    (p.nombre + " " + (p.referencia || "") + " " + (p.proveedor || "")).toLowerCase().includes(busqueda.toLowerCase())
  );

  function guardarNueva(datos) {
    const nueva = { ...datos, id: uid("pz") };
    setPiezas((prev) => [...prev, nueva]);
    setModal(null);
    notify("Pieza añadida al inventario.");
  }
  function guardarEdicion(datos) {
    setPiezas((prev) => prev.map((p) => (p.id === modal.edit.id ? { ...p, ...datos } : p)));
    setModal(null);
    notify("Pieza actualizada.");
  }
  function eliminar(id) {
    setPiezas((prev) => prev.filter((p) => p.id !== id));
    setConfirmDelete(null);
    notify("Pieza eliminada.");
  }

  return (
    <div>
      <div className="page-head">
        <div>
          <div className="page-eyebrow">Administración</div>
          <div className="page-title">Piezas y stock</div>
        </div>
        <button className="btn btn-primary" onClick={() => setModal("nueva")}>
          <span style={{ display: "inline-flex", alignItems: "center", gap: 6 }}><Ico.mas style={{ width: 15, height: 15 }} /> Añadir pieza</span>
        </button>
      </div>

      <div className="search-bar">
        <input
          placeholder="Buscar por nombre, referencia o proveedor…"
          value={busqueda}
          onChange={(e) => setBusqueda(e.target.value)}
        />
      </div>

      <div className="card">
        {filtradas.length === 0 ? (
          <div className="empty-state">
            <Ico.piezas />
            <div className="empty-state-title">{piezas.length === 0 ? "Todavía no hay piezas registradas" : "Sin resultados"}</div>
            <div className="empty-state-sub">{piezas.length === 0 ? "Añade la primera pieza al inventario del taller." : "Prueba con otro término de búsqueda."}</div>
          </div>
        ) : (
          <div className="table-wrap">
            <table>
              <thead>
                <tr><th>Pieza</th><th>Referencia</th><th>Precio</th><th>Stock</th><th>Proveedor</th><th></th></tr>
              </thead>
              <tbody>
                {filtradas.map((p) => (
                  <tr key={p.id}>
                    <td>{p.nombre}</td>
                    <td>{p.referencia || "—"}</td>
                    <td>{euros(p.precio)}</td>
                    <td>
                      {p.stock}
                      {Number(p.stock) <= Number(p.stockMin || 0) && (
                        <span className="badge badge-pend" style={{ marginLeft: 8 }}>Stock bajo</span>
                      )}
                    </td>
                    <td>{p.proveedor || "—"}</td>
                    <td>
                      <div style={{ display: "flex", gap: 4 }}>
                        <button className="icon-btn" title="Editar" onClick={() => setModal({ edit: p })}><Ico.editar /></button>
                        <button className="icon-btn danger" title="Eliminar" onClick={() => setConfirmDelete(p)}><Ico.borrar /></button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

      {modal === "nueva" && (
        <Modal title="Añadir pieza" onClose={() => setModal(null)}>
          <FormPieza onSave={guardarNueva} onCancel={() => setModal(null)} />
        </Modal>
      )}
      {modal && modal !== "nueva" && (
        <Modal title="Editar pieza" onClose={() => setModal(null)}>
          <FormPieza inicial={modal.edit} onSave={guardarEdicion} onCancel={() => setModal(null)} />
        </Modal>
      )}
      {confirmDelete && (
        <Modal title="Eliminar pieza" onClose={() => setConfirmDelete(null)}>
          <p>¿Seguro que quieres eliminar <strong>{confirmDelete.nombre}</strong> del inventario? Esta acción no se puede deshacer.</p>
          <div className="btn-row">
            <button className="btn btn-danger" onClick={() => eliminar(confirmDelete.id)}>Eliminar definitivamente</button>
            <button className="btn btn-secondary" onClick={() => setConfirmDelete(null)}>Cancelar</button>
          </div>
        </Modal>
      )}
    </div>
  );
}

