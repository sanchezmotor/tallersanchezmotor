                    <td>{euros(f.total)}</td>
                    <td><span className={"badge " + (f.estado === "pagada" ? "badge-ok" : "badge-pend")}>{f.estado === "pagada" ? "Pagada" : "Pendiente"}</span></td>
                    <td><button className="icon-btn" onClick={(e) => { e.stopPropagation(); abrirFactura(f); }}><Ico.ojo /></button></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  );
}

/* ============ APP PRINCIPAL ============ */
function App() {
  const [cargando, setCargando] = useState(true);
  const [logueado, setLogueado] = useState(false);
  const [view, setView] = useState("panel");
  const [mobileOpen, setMobileOpen] = useState(false);
  const [toast, setToast] = useState(null);

  const [clientes, setClientes] = useState([]);
  const [piezas, setPiezas] = useState([]);
  const [facturas, setFacturas] = useState([]);
  const [contadorFactura, setContadorFactura] = useState(1);

  const [fichaAbiertaId, setFichaAbiertaId] = useState(null);
  const [modalFacturaCliente, setModalFacturaCliente] = useState(null); // cliente para construir factura
  const [facturaAbierta, setFacturaAbierta] = useState(null);

  const notify = useCallback((msg, type) => setToast({ msg, type, t: Date.now() }), []);

  /* ---- Carga inicial desde storage ---- */
  useEffect(() => {
    async function cargar() {
      const sesion = await dbGet("sesion_activa", false);
      const cl = await dbGet("clientes", []);
      const pz = await dbGet("piezas", []);
      const fa = await dbGet("facturas", []);
      const ct = await dbGet("contador_factura", 1);
      setClientes(cl);
      setPiezas(pz);
      setFacturas(fa);
      setContadorFactura(ct);
      setLogueado(!!sesion);
      setCargando(false);
    }
    cargar();
  }, []);

  /* ---- Persistencia automática ---- */
  useEffect(() => { if (!cargando) dbSet("clientes", clientes); }, [clientes, cargando]);
  useEffect(() => { if (!cargando) dbSet("piezas", piezas); }, [piezas, cargando]);
  useEffect(() => { if (!cargando) dbSet("facturas", facturas); }, [facturas, cargando]);
  useEffect(() => { if (!cargando) dbSet("contador_factura", contadorFactura); }, [contadorFactura, cargando]);

  function handleLogin() {
    setLogueado(true);
    dbSet("sesion_activa", true);
  }
  function handleLogout() {
    setLogueado(false);
    dbSet("sesion_activa", false);
    setView("panel");
    setFichaAbiertaId(null);
    setFacturaAbierta(null);
  }

  function abrirFicha(clienteId) {
    setFichaAbiertaId(clienteId);
    setView("ficha");
  }
  function volverDeFicha() {
    setFichaAbiertaId(null);
    setView("clientes");
  }

  function abrirFactura(factura) {
    setFacturaAbierta(factura);
    setView("verFactura");
  }
  function volverDeFactura() {
    setFacturaAbierta(null);
    setView("facturas");
  }

  function generarFactura(cliente, datos) {
    const year = new Date().getFullYear();
    const numero = numeroFactura(contadorFactura, year);
    const fecha = hoy();
    const lineas = datos.trabajosSel.map((t) => ({
      descripcion: t.descripcion,
      piezasTexto: (t.piezas || []).map((p) => `${p.nombre} (x${p.cantidad})`).join(", "),
      total: t.total,
    }));
    const ultimaFactura = facturas[facturas.length - 1];
    const cadenaPrevia = ultimaFactura ? ultimaFactura.hash : "INICIO";
    const hash = hashSimple(`${cadenaPrevia}|${numero}|${fecha}|${datos.total.toFixed(2)}|${cliente.id}`);

    const nuevaFactura = {
      id: uid("fac"),
      numero,
      fecha,
      clienteId: cliente.id,
      clienteNombre: cliente.nombre,
      clienteDni: cliente.dni,
      clienteDireccion: cliente.direccion,
      clienteTelefono: cliente.telefono,
      vehiculoMarca: cliente.marca,
      vehiculoModelo: cliente.modelo,
      vehiculoMatricula: cliente.matricula,
      vehiculoAnio: cliente.anio,
      lineas,
      base: datos.base,
      ivaPct: datos.ivaPct,
      iva: datos.iva,
      total: datos.total,
      observaciones: datos.observaciones,
      estado: "pendiente",
      hash,
      hashAnterior: cadenaPrevia,
    };

    setFacturas((prev) => [...prev, nuevaFactura]);
    setContadorFactura((prev) => prev + 1);

    // marcar los trabajos facturados como completados
    const idsSel = datos.trabajosSel.map((t) => t.id);
    setClientes((prev) => prev.map((c) => {
      if (c.id !== cliente.id) return c;
      return { ...c, trabajos: (c.trabajos || []).map((t) => idsSel.includes(t.id) ? { ...t, estado: "completado" } : t) };
    }));

    setModalFacturaCliente(null);
    notify("Factura " + numero + " generada correctamente.");
    abrirFactura(nuevaFactura);
  }

  function marcarEstadoFactura(facturaId, estado) {
    setFacturas((prev) => prev.map((f) => f.id === facturaId ? { ...f, estado } : f));
    setFacturaAbierta((prev) => prev && prev.id === facturaId ? { ...prev, estado } : prev);
    notify(estado === "pagada" ? "Factura marcada como pagada." : "Factura marcada como pendiente.");
  }

  if (cargando) {
    return (
      <div style={{ display: "flex", alignItems: "center", justifyContent: "center", minHeight: "100vh", color: "var(--azul-700)" }}>
        <div style={{ textAlign: "center" }}>
          <LogoMark size={50} />
          <div style={{ marginTop: 10, fontSize: "0.85rem", textTransform: "uppercase", letterSpacing: "0.08em" }}>Cargando taller…</div>
        </div>
      </div>
    );
  }

  if (!logueado) {
    return <Login onLogin={handleLogin} />;
  }

  const clienteFicha = clientes.find((c) => c.id === fichaAbiertaId);

  let contenido;
  if (view === "panel") {
    contenido = <Panel clientes={clientes} facturas={facturas} piezas={piezas} setView={setView} />;
  } else if (view === "clientes") {
    contenido = (
      <Clientes
        clientes={clientes}
        setClientes={setClientes}
        piezas={piezas}
        facturas={facturas}
        setFacturas={setFacturas}
        notify={notify}
        abrirFicha={abrirFicha}
      />
    );
  } else if (view === "piezas") {
    contenido = <Piezas piezas={piezas} setPiezas={setPiezas} notify={notify} />;
  } else if (view === "facturas") {
    contenido = <Facturas facturas={facturas} setFacturas={setFacturas} abrirFactura={abrirFactura} notify={notify} />;
  } else if (view === "ficha" && clienteFicha) {
    contenido = (
      <FichaCliente
        cliente={clienteFicha}
        setClientes={setClientes}
        piezas={piezas}
        onVolver={volverDeFicha}
        onFacturar={(c) => setModalFacturaCliente(c)}
        notify={notify}
      />
    );
  } else if (view === "verFactura" && facturaAbierta) {
    contenido = (
      <VistaFactura factura={facturaAbierta} onVolver={volverDeFactura} onMarcarEstado={marcarEstadoFactura} />
    );
  } else {
    contenido = <Panel clientes={clientes} facturas={facturas} piezas={piezas} setView={setView} />;
  }

  return (
    <React.Fragment>
      <AppShell view={view === "ficha" ? "clientes" : (view === "verFactura" ? "facturas" : view)} setView={setView} onLogout={handleLogout} mobileOpen={mobileOpen} setMobileOpen={setMobileOpen}>
        {contenido}
      </AppShell>
      <Toast toast={toast} onClose={() => setToast(null)} />
      {modalFacturaCliente && (
        <Modal title={"Generar factura — " + modalFacturaCliente.nombre} onClose={() => setModalFacturaCliente(null)} wide>
          <ConstructorFactura
            cliente={modalFacturaCliente}
            facturas={facturas}
            onGenerar={(datos) => generarFactura(modalFacturaCliente, datos)}
            onCancel={() => setModalFacturaCliente(null)}
          />
        </Modal>
      )}
    </React.Fragment>
  );
}

const root = ReactDOM.createRoot(document.getElementById("root"));
root.render(<App />);

</script>
</body>
</html>
